<div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 mb-5">
  <div class="flex items-center gap-2 mb-3">
    <h3 class="text-sm font-semibold">Add New Device</h3>
    <% if (user.role === 'user') { %>
      <span class="text-[11px] text-gray-400">(max 2 devices)</span>
    <% } %>
  </div>
  <form method="POST" action="/devices/create" class="flex flex-wrap gap-3 items-end">
    <input type="text" name="sessionId" placeholder="Session ID (e.g. device-1)" required
      class="flex-1 min-w-[200px] px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition">
    <input type="text" name="name" placeholder="Device Name (optional)"
      class="flex-1 min-w-[200px] px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition">
    <% if (user.role === 'manager' && staffList && staffList.length > 0) { %>
      <select name="assignTo"
        class="min-w-[160px] px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition">
        <option value="">Assign to: Myself</option>
        <% staffList.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.name %></option>
        <% }) %>
      </select>
    <% } %>
    <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition shadow-sm">Add Device</button>
  </form>
</div>

<!-- Filters -->
<div class="flex flex-wrap items-center gap-2 mb-5">
  <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">Status:</span>
  <% ['all','connected','connecting','reconnecting','scan_qr','failed','offline'].forEach(s => { %>
    <a href="/devices?status=<%= s %>"
      class="px-3 py-1.5 rounded-lg text-xs font-medium transition
        <%= statusFilter === s
          ? 'bg-green-600 text-white shadow-sm'
          : 'bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800' %>">
      <%= s === 'all' ? 'All' : s === 'scan_qr' ? 'Scan QR' : s.charAt(0).toUpperCase() + s.slice(1) %>
    </a>
  <% }) %>
  <span class="ml-auto text-xs text-gray-400"><%= pagination.total %> devices</span>
</div>

<!-- Device Table -->
<div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-100 dark:border-gray-800">
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Device</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Session ID</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">API Key</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Status</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">QR</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Webhook</th>
        <th class="px-5 py-2.5 text-left text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Created By</th>
        <th class="px-5 py-2.5 text-right text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
      <% if (devices.length === 0) { %>
        <tr><td colspan="8" class="px-5 py-10 text-center text-gray-400">No devices found</td></tr>
      <% } %>
      <% devices.forEach(d => { %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors" id="device-<%= d.id || d.sessionId %>" data-session="<%= d.sessionId %>">
          <td class="px-5 py-3 font-medium">
            <div class="flex items-center gap-1.5">
              <span id="dname-<%= d.id %>"><%= d.name || d.sessionId %></span>
              <% if (!d.id) { %>
                <span class="text-[10px] text-amber-500 font-normal">(unregistered)</span>
              <% } else if (user.role === 'superadmin' || user.role === 'manager') { %>
                <button onclick="renameDevice(<%= d.id %>, '<%= (d.name || d.sessionId).replace(/'/g, "\\'") %>')" class="text-gray-400 hover:text-blue-500 transition" title="Rename">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                </button>
              <% } %>
            </div>
          </td>
          <td class="px-5 py-3 text-gray-500 dark:text-gray-400 font-mono text-xs"><%= d.sessionId %></td>
          <td class="px-5 py-3">
            <% if (d.apiKey) { %>
              <div class="flex items-center gap-1">
                <code class="text-[10px] font-mono text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded max-w-[120px] truncate" id="apikey-<%= d.id %>" title="<%= d.apiKey %>"><%= d.apiKey.substring(0,8) %>...</code>
                <button onclick="copyApiKey('<%= d.apiKey %>')" class="text-gray-400 hover:text-green-500 transition" title="Copy API Key">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
                </button>
              </div>
            <% } else { %>
              <span class="text-xs text-gray-400">—</span>
            <% } %>
          </td>
          <td class="px-5 py-3">
            <span class="status-badge inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[11px] font-medium
              <%= d.liveStatus === 'connected' ? 'bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400' :
                 d.liveStatus === 'scan_qr' ? 'bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400' :
                 d.liveStatus === 'connecting' ? 'bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400' :
                 d.liveStatus === 'reconnecting' ? 'bg-orange-100 dark:bg-orange-500/10 text-orange-700 dark:text-orange-400' :
                 d.liveStatus === 'failed' ? 'bg-red-100 dark:bg-red-500/10 text-red-700 dark:text-red-400' :
                 'bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400' %>">
              <span class="w-1.5 h-1.5 rounded-full
                <%= d.liveStatus === 'connected' ? 'bg-green-500' :
                   d.liveStatus === 'scan_qr' ? 'bg-blue-500' :
                   d.liveStatus === 'connecting' ? 'bg-amber-500' :
                   d.liveStatus === 'reconnecting' ? 'bg-orange-500 animate-pulse' :
                   d.liveStatus === 'failed' ? 'bg-red-500' : 'bg-gray-400' %>"></span>
              <%= d.liveStatus %>
            </span>
          </td>
          <td class="px-5 py-3 qr-cell">
            <% if (d.liveStatus === 'connected') { %>
              <span class="text-green-600 dark:text-green-400 text-xs">✓ Paired</span>
            <% } else if (d.qr) { %>
              <button onclick="showQR(this)" data-qr="<%= d.qr %>" class="text-xs text-blue-600 dark:text-blue-400 hover:underline font-medium">View QR</button>
            <% } else { %>
              <span class="text-xs text-gray-400">—</span>
            <% } %>
          </td>
          <td class="px-5 py-3">
            <% if (d.webhookUrl) { %>
              <span class="text-xs text-gray-500 dark:text-gray-400 max-w-[180px] truncate block" title="<%= d.webhookUrl %>"><%= d.webhookUrl %></span>
            <% } else { %>
              <span class="text-xs text-gray-400">—</span>
            <% } %>
          </td>
          <td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400"><%= d.creator ? d.creator.name : (d.id ? '—' : 'API') %></td>
          <td class="px-5 py-3 text-right">
            <% if (d.id) { %>
              <div class="flex items-center justify-end gap-1">
                <% if (d.liveStatus === 'connected') { %>
                  <button onclick="openGroupsModal(<%= d.id %>, '<%= (d.name || d.sessionId).replace(/'/g, "\\'") %>')" class="px-2.5 py-1 text-xs font-medium text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-500/10 rounded transition">Groups</button>
                <% } %>
                <form method="POST" action="/devices/<%= d.id %>/restart" class="inline">
                  <button type="submit" class="px-2.5 py-1 text-xs font-medium text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 rounded transition">Restart</button>
                </form>
                <% if (user.role === 'superadmin' || user.role === 'manager') { %>
                  <button onclick="openWebhookModal(<%= d.id %>, '<%= (d.webhookUrl || '').replace(/'/g, "\\'") %>')" class="px-2.5 py-1 text-xs font-medium text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded transition">Webhook</button>
                  <form method="POST" action="/devices/<%= d.id %>/regenerate-key" class="inline" onsubmit="return confirm('Regenerate API key? The old key will stop working.')">
                    <button type="submit" class="px-2.5 py-1 text-xs font-medium text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 rounded transition">Regen Key</button>
                  </form>
                  <form method="POST" action="/devices/<%= d.id %>/delete" class="inline" onsubmit="return confirm('Remove this device?')">
                    <button type="submit" class="px-2.5 py-1 text-xs font-medium text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 rounded transition">Remove</button>
                  </form>
                <% } %>
              </div>
            <% } else if (user.role === 'superadmin') { %>
              <div class="flex items-center justify-end gap-1">
                <form method="POST" action="/devices/session/<%= encodeURIComponent(d.sessionId) %>/delete" class="inline" onsubmit="return confirm('Remove this unregistered session?')">
                  <button type="submit" class="px-2.5 py-1 text-xs font-medium text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 rounded transition">Remove Session</button>
                </form>
              </div>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
  <div class="flex items-center justify-between mt-4">
    <p class="text-xs text-gray-500 dark:text-gray-400">Page <%= pagination.page %> of <%= pagination.totalPages %></p>
    <div class="flex gap-2">
      <% if (pagination.page > 1) { %>
        <a href="/devices?status=<%= statusFilter %>&page=<%= pagination.page - 1 %>" class="px-3 py-1.5 text-xs border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">← Previous</a>
      <% } %>
      <% if (pagination.page < pagination.totalPages) { %>
        <a href="/devices?status=<%= statusFilter %>&page=<%= pagination.page + 1 %>" class="px-3 py-1.5 text-xs border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">Next →</a>
      <% } %>
    </div>
  </div>
<% } %>

<!-- QR Modal -->
<div id="qrModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50" onclick="if(event.target===this)closeQR()">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 shadow-xl border border-gray-200 dark:border-gray-800 max-w-sm w-full mx-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold">Scan QR Code</h3>
      <button onclick="closeQR()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">&times;</button>
    </div>
    <div class="flex flex-col items-center justify-center min-h-[200px]">
      <div id="qrLoading" class="flex flex-col items-center gap-3">
        <div class="w-8 h-8 border-3 border-gray-200 dark:border-gray-700 border-t-green-500 rounded-full animate-spin"></div>
        <p class="text-xs text-gray-500">Waiting for QR code...</p>
      </div>
      <img id="qrImage" src="" alt="QR Code" class="max-w-full rounded-lg hidden">
      <div id="qrConnected" class="flex flex-col items-center gap-2 hidden">
        <span class="text-3xl">✅</span>
        <p class="text-sm font-medium text-green-600">Device Connected!</p>
      </div>
    </div>
  </div>
</div>

<!-- Webhook Modal -->
<div id="webhookModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50" onclick="if(event.target===this)closeWebhook()">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 shadow-xl border border-gray-200 dark:border-gray-800 max-w-md w-full mx-4">
    <h3 class="text-sm font-semibold mb-4">Update Webhook URL</h3>
    <form id="webhookForm" method="POST" class="space-y-3">
      <input type="text" name="webhookUrl" id="webhookInput"
        class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition"
        placeholder="https://example.com/webhook">
      <div class="flex gap-2">
        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Save</button>
        <button type="button" onclick="closeWebhook()" class="px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Groups Modal -->
<div id="groupsModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50" onclick="if(event.target===this)closeGroups()">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 shadow-xl border border-gray-200 dark:border-gray-800 max-w-lg w-full mx-4 max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold">Groups — <span id="groupsDeviceName"></span></h3>
      <button onclick="closeGroups()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">&times;</button>
    </div>
    <div id="groupsLoading" class="flex flex-col items-center gap-3 py-8">
      <div class="w-8 h-8 border-3 border-gray-200 dark:border-gray-700 border-t-purple-500 rounded-full animate-spin"></div>
      <p class="text-xs text-gray-500">Fetching groups...</p>
    </div>
    <div id="groupsError" class="hidden text-center py-8">
      <p class="text-sm text-red-500" id="groupsErrorMsg"></p>
    </div>
    <div id="groupsList" class="hidden overflow-y-auto flex-1">
      <input type="text" id="groupsSearch" placeholder="Search groups..." oninput="filterGroups()"
        class="w-full px-3 py-2 mb-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 transition">
      <div class="text-xs text-gray-400 mb-2"><span id="groupsCount">0</span> groups</div>
      <div id="groupsBody" class="space-y-2"></div>
    </div>
  </div>
</div>

<script>
  let qrPollInterval = null;

  function showQR(btn) {
    document.getElementById('qrLoading').classList.add('hidden');
    document.getElementById('qrConnected').classList.add('hidden');
    document.getElementById('qrImage').src = btn.dataset.qr;
    document.getElementById('qrImage').classList.remove('hidden');
    document.getElementById('qrModal').classList.remove('hidden');
    document.getElementById('qrModal').classList.add('flex');
  }

  function openQRWithPolling(deviceId) {
    // Show modal with loading state
    document.getElementById('qrImage').classList.add('hidden');
    document.getElementById('qrConnected').classList.add('hidden');
    document.getElementById('qrLoading').classList.remove('hidden');
    document.getElementById('qrModal').classList.remove('hidden');
    document.getElementById('qrModal').classList.add('flex');

    // Poll for QR
    if (qrPollInterval) clearInterval(qrPollInterval);
    qrPollInterval = setInterval(async () => {
      try {
        const res = await fetch('/devices/' + deviceId + '/status');
        const data = await res.json();
        if (data.status === 'connected') {
          clearInterval(qrPollInterval);
          qrPollInterval = null;
          document.getElementById('qrLoading').classList.add('hidden');
          document.getElementById('qrImage').classList.add('hidden');
          document.getElementById('qrConnected').classList.remove('hidden');
          setTimeout(() => { closeQR(); location.reload(); }, 1500);
        } else if (data.qr) {
          document.getElementById('qrLoading').classList.add('hidden');
          document.getElementById('qrConnected').classList.add('hidden');
          document.getElementById('qrImage').src = data.qr;
          document.getElementById('qrImage').classList.remove('hidden');
        }
      } catch(e) {}
    }, 2000);
  }

  function closeQR() {
    if (qrPollInterval) { clearInterval(qrPollInterval); qrPollInterval = null; }
    document.getElementById('qrModal').classList.add('hidden');
    document.getElementById('qrModal').classList.remove('flex');
  }

  function copyApiKey(key) {
    navigator.clipboard.writeText(key).then(() => {
      alert('API Key copied!');
    });
  }

  function renameDevice(id, currentName) {
    const newName = prompt('Enter new device name:', currentName);
    if (newName === null || newName.trim() === '' || newName === currentName) return;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/devices/' + id + '/name';
    const input = document.createElement('input');
    input.type = 'hidden'; input.name = 'name'; input.value = newName.trim();
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  }
  function openWebhookModal(id, url) {
    document.getElementById('webhookForm').action = '/devices/' + id + '/webhook';
    document.getElementById('webhookInput').value = url;
    document.getElementById('webhookModal').classList.remove('hidden');
    document.getElementById('webhookModal').classList.add('flex');
  }
  function closeWebhook() {
    document.getElementById('webhookModal').classList.add('hidden');
    document.getElementById('webhookModal').classList.remove('flex');
  }

  let _cachedGroups = [];

  async function openGroupsModal(deviceId, deviceName) {
    _cachedGroups = [];
    document.getElementById('groupsDeviceName').textContent = deviceName;
    document.getElementById('groupsLoading').classList.remove('hidden');
    document.getElementById('groupsError').classList.add('hidden');
    document.getElementById('groupsList').classList.add('hidden');
    document.getElementById('groupsModal').classList.remove('hidden');
    document.getElementById('groupsModal').classList.add('flex');
    try {
      const res = await fetch('/devices/' + deviceId + '/groups');
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      _cachedGroups = data.groups || [];
      document.getElementById('groupsSearch').value = '';
      renderGroups(_cachedGroups);
      document.getElementById('groupsLoading').classList.add('hidden');
      document.getElementById('groupsList').classList.remove('hidden');
      document.getElementById('groupsSearch').focus();
    } catch (err) {
      document.getElementById('groupsLoading').classList.add('hidden');
      document.getElementById('groupsErrorMsg').textContent = err.message;
      document.getElementById('groupsError').classList.remove('hidden');
    }
  }
  function renderGroups(groups) {
    document.getElementById('groupsCount').textContent = groups.length;
    const body = document.getElementById('groupsBody');
    if (groups.length === 0) {
      body.innerHTML = '<p class="text-sm text-gray-400 text-center py-4">No groups found</p>';
    } else {
      body.innerHTML = groups.map(g => `
        <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium truncate">${escapeHtml(g.subject)}</p>
            <p class="text-[11px] text-gray-500 dark:text-gray-400 font-mono">${g.id}</p>
          </div>
          <div class="flex items-center gap-2 ml-3 shrink-0">
            <span class="text-[10px] text-gray-400">${g.size} members</span>
            <button onclick="copyGroupId('${g.id}')" class="text-gray-400 hover:text-purple-500 transition" title="Copy Group JID">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            </button>
          </div>
        </div>
      `).join('');
    }
  }
  function filterGroups() {
    const q = document.getElementById('groupsSearch').value.toLowerCase();
    if (!q) { renderGroups(_cachedGroups); return; }
    renderGroups(_cachedGroups.filter(g => g.subject.toLowerCase().includes(q) || g.id.toLowerCase().includes(q)));
  }
  function closeGroups() {
    document.getElementById('groupsModal').classList.add('hidden');
    document.getElementById('groupsModal').classList.remove('flex');
  }
  function copyGroupId(id) {
    navigator.clipboard.writeText(id).then(() => alert('Group JID copied!'));
  }
  function escapeHtml(str) {
    const d = document.createElement('div'); d.textContent = str; return d.innerHTML;
  }

  // Auto-open QR modal for newly created device
  const urlParams = new URLSearchParams(window.location.search);
  const newDeviceId = urlParams.get('new');
  if (newDeviceId) {
    openQRWithPolling(newDeviceId);
    // Clean up URL
    window.history.replaceState({}, '', '/devices');
  }

  // Auto-refresh status badges
  setInterval(async () => {
    const rows = document.querySelectorAll('[data-session]');
    for (const row of rows) {
      const idPart = row.id.replace('device-', '');
      if (!idPart || isNaN(idPart)) continue;
      try {
        const res = await fetch('/devices/' + idPart + '/status');
        const data = await res.json();
        if (!data.status) continue;
        const badge = row.querySelector('.status-badge');
        const qrCell = row.querySelector('.qr-cell');
        const colors = { connected: 'bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400', scan_qr: 'bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400', connecting: 'bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400', reconnecting: 'bg-orange-100 dark:bg-orange-500/10 text-orange-700 dark:text-orange-400', failed: 'bg-red-100 dark:bg-red-500/10 text-red-700 dark:text-red-400' };
        const dots = { connected: 'bg-green-500', scan_qr: 'bg-blue-500', connecting: 'bg-amber-500', reconnecting: 'bg-orange-500 animate-pulse', failed: 'bg-red-500' };
        badge.className = 'status-badge inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[11px] font-medium ' + (colors[data.status] || 'bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400');
        badge.innerHTML = '<span class="w-1.5 h-1.5 rounded-full ' + (dots[data.status] || 'bg-gray-400') + '"></span>' + data.status;
        if (data.status === 'connected') {
          qrCell.innerHTML = '<span class="text-green-600 dark:text-green-400 text-xs">✓ Paired</span>';
        } else if (data.qr) {
          qrCell.innerHTML = '<button onclick="showQR(this)" data-qr="' + data.qr + '" class="text-xs text-blue-600 dark:text-blue-400 hover:underline font-medium">View QR</button>';
        }
      } catch(e) {}
    }
  }, 3000);
</script>

