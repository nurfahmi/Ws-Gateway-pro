<link rel="stylesheet" href="/css/chat.css">

<div class="wa-container">
  <div class="wa-sidebar">
    <div class="wa-sidebar-header">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--wa-green)" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <div class="wa-device-filter-wrap" style="position:relative;flex:1">
        <input type="text" id="deviceSearchInput" placeholder="All Devices" class="wa-device-select" style="cursor:text" autocomplete="off">
        <select class="wa-device-select" id="deviceFilter" style="display:none">
          <option value="">All Devices</option>
          <% devices.forEach(d => { %>
            <option value="<%= d.sessionId %>" data-status="<%= d.status %>"><%= d.name || d.sessionId %><%= d.phoneNumber ? ` (${d.phoneNumber})` : '' %></option>
          <% }) %>
        </select>
        <div id="deviceDropdown" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:60;max-height:250px;overflow-y:auto;background:var(--wa-bg-sidebar);border:1px solid var(--wa-border);border-radius:8px;margin-top:2px;">
          <div class="dd-option" data-value="" style="padding:8px 12px;font-size:13px;cursor:pointer;">✓ All Devices</div>
          <% devices.forEach(d => { %>
            <div class="dd-option" data-value="<%= d.sessionId %>" style="padding:8px 12px;font-size:13px;cursor:pointer;"><%= d.name || d.sessionId %><%= d.phoneNumber ? ` (${d.phoneNumber})` : '' %></div>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="wa-search-bar">
      <div class="wa-search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" class="wa-search-input" id="chatSearch" placeholder="Search or start new chat">
      </div>
    </div>
    <div class="wa-chat-list" id="chatList">
      <div class="wa-loading"><div class="wa-spinner"></div> Loading chats...</div>
    </div>
  </div>

  <div class="wa-main" id="waMain">
    <div class="wa-empty-state" id="emptyState">
      <svg width="200" height="200" viewBox="0 0 303 172" fill="currentColor"><path d="M229.565 160.229c32.647-16.166 55.388-50.156 55.388-89.428 0-55.178-44.823-99.5-100.5-99.5-40.083 0-74.716 23.346-90.927 57.073C38.815 30.072 0 68.926 0 115.129c0 21.313 7.584 40.875 20.2 56.143l-15.168 23.467c-.563.870-.133 2.033.875 2.37l27.091 9.061c9.477 3.164 19.725-.104 25.907-7.477C72.083 208.074 88.406 213 105.931 213c31.47 0 58.381-19.152 69.888-46.423 12.576 6.736 27.026 10.551 42.284 10.551 13.458 0 26.21-3.082 37.591-8.583l22.193 15.674c.874.617 2.08.076 2.252-.998l3.621-22.594c.104-.648-.261-1.282-.867-1.518-9.17-3.576-17.363-8.802-24.253-15.37-8.654 5.027-18.452 8.496-28.91 10.091l-.165.399z"/></svg>
      <h3>WhatsApp Chat</h3>
      <p>Select a conversation to start chatting</p>
    </div>
  </div>

  <!-- Contact Info Panel -->
  <div class="wa-info-panel" id="infoPanel">
    <div class="wa-info-header">
      <button onclick="window.__closeInfo()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <span>Contact Info</span>
    </div>
    <div class="wa-info-body"></div>
  </div>
</div>

<!-- Emoji Picker -->
<div class="wa-emoji-picker" id="emojiPicker">
  <input type="text" class="wa-emoji-search" placeholder="Search emoji..." oninput="window.__searchEmoji && window.__searchEmoji(this.value)">
  <div class="wa-emoji-grid"></div>
</div>

<!-- Context Menu -->
<div class="wa-ctx-menu" id="ctxMenu">
  <button class="wa-ctx-item" onclick="window.__ctxCopy()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    Copy text
  </button>
</div>

<input type="file" id="fileInput" accept="image/*,video/mp4,.pdf,.doc,.docx" hidden>

<script>window.__devices = <%- JSON.stringify(devices) %>;</script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/chat.js"></script>

<script>
(function() {
  const input = document.getElementById('deviceSearchInput');
  const dropdown = document.getElementById('deviceDropdown');
  const select = document.getElementById('deviceFilter');
  const options = dropdown.querySelectorAll('.dd-option');

  input.addEventListener('focus', () => { dropdown.style.display = 'block'; filter(); });
  input.addEventListener('input', filter);

  function filter() {
    const q = input.value.toLowerCase();
    options.forEach(o => {
      o.style.display = o.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  }

  options.forEach(o => {
    o.addEventListener('mouseenter', () => o.style.background = 'var(--wa-hover)');
    o.addEventListener('mouseleave', () => o.style.background = '');
    o.addEventListener('click', () => {
      const val = o.dataset.value;
      select.value = val;
      input.value = val ? o.textContent : '';
      input.placeholder = val ? o.textContent : 'All Devices';
      dropdown.style.display = 'none';
      // Trigger change event so chat.js reloads chats
      select.dispatchEvent(new Event('change'));
    });
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.wa-device-filter-wrap')) dropdown.style.display = 'none';
  });
})();
</script>
