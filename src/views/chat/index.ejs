<style>
  /* Override layout padding for full-bleed chat */
  .main-content { padding: 0 !important; }
  
  :root {
    --wa-green: #00a884;
    --wa-green-dark: #008069;
    --wa-bg: #efeae2;
    --wa-sidebar-bg: #ffffff;
    --wa-header-bg: #f0f2f5;
    --wa-chat-bg: #efeae2;
    --wa-bubble-out: #d9fdd3;
    --wa-bubble-in: #ffffff;
    --wa-text: #111b21;
    --wa-text-secondary: #667781;
    --wa-border: #e9edef;
    --wa-hover: #f5f6f6;
    --wa-active: #2a3942;
    --wa-search-bg: #f0f2f5;
    --wa-doodle: rgba(0,0,0,0.03);
  }

  .dark {
    --wa-green: #00a884;
    --wa-green-dark: #00a884;
    --wa-bg: #0b141a;
    --wa-sidebar-bg: #111b21;
    --wa-header-bg: #202c33;
    --wa-chat-bg: #0b141a;
    --wa-bubble-out: #005c4b;
    --wa-bubble-in: #202c33;
    --wa-text: #e9edef;
    --wa-text-secondary: #8696a0;
    --wa-border: #2a3942;
    --wa-hover: #202c33;
    --wa-active: #2a3942;
    --wa-search-bg: #202c33;
    --wa-doodle: rgba(255,255,255,0.03);
  }

  .wa-container {
    display: flex;
    height: calc(100vh - 56px);
    background: var(--wa-bg);
    overflow: hidden;
  }

  /* ─── Sidebar ─── */
  .wa-sidebar {
    width: 420px;
    min-width: 320px;
    max-width: 420px;
    background: var(--wa-sidebar-bg);
    border-right: 1px solid var(--wa-border);
    display: flex;
    flex-direction: column;
  }

  .wa-sidebar-header {
    background: var(--wa-header-bg);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 56px;
    border-bottom: 1px solid var(--wa-border);
  }

  .wa-device-select {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid var(--wa-border);
    border-radius: 8px;
    background: var(--wa-sidebar-bg);
    color: var(--wa-text);
    font-size: 14px;
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .wa-device-select:focus { border-color: var(--wa-green); }

  .wa-search-bar {
    padding: 8px 12px;
    background: var(--wa-sidebar-bg);
    border-bottom: 1px solid var(--wa-border);
  }

  .wa-search-input {
    width: 100%;
    padding: 8px 32px 8px 36px;
    border: none;
    border-radius: 8px;
    background: var(--wa-search-bg);
    color: var(--wa-text);
    font-size: 13.5px;
    outline: none;
  }
  .wa-search-input::placeholder { color: var(--wa-text-secondary); }

  .wa-search-wrap {
    position: relative;
  }
  .wa-search-wrap svg {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--wa-text-secondary);
  }

  .wa-chat-list {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.15) transparent;
  }

  .wa-chat-item {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    gap: 14px;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid var(--wa-border);
  }
  .wa-chat-item:hover { background: var(--wa-hover); }
  .wa-chat-item.active { background: var(--wa-hover); }

  .wa-avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 18px;
    color: #fff;
  }

  .wa-chat-info {
    flex: 1;
    min-width: 0;
  }

  .wa-chat-name-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .wa-chat-name {
    font-size: 16px;
    font-weight: 400;
    color: var(--wa-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .wa-device-label {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    background: var(--wa-green);
    color: #fff;
    white-space: nowrap;
    flex-shrink: 0;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .wa-chat-preview {
    font-size: 13px;
    color: var(--wa-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .wa-chat-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }

  .wa-chat-time {
    font-size: 12px;
    color: var(--wa-text-secondary);
    white-space: nowrap;
  }

  .wa-chat-badge {
    background: var(--wa-green);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    min-width: 20px;
    height: 20px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5px;
  }

  /* ─── Main Chat Area ─── */
  .wa-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--wa-chat-bg);
    position: relative;
  }

  .wa-main-header {
    background: var(--wa-header-bg);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    min-height: 56px;
    border-bottom: 1px solid var(--wa-border);
  }

  .wa-main-header .wa-chat-name { font-size: 16px; font-weight: 500; }
  .wa-main-header .wa-chat-preview { font-size: 13px; margin-top: 0; }

  /* Chat background pattern */
  .wa-messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 60px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    background-image:
      radial-gradient(circle at 20% 30%, var(--wa-doodle) 1px, transparent 1px),
      radial-gradient(circle at 80% 70%, var(--wa-doodle) 1px, transparent 1px);
    background-size: 40px 40px;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.15) transparent;
  }

  .wa-bubble-wrap {
    display: flex;
    margin-bottom: 2px;
  }
  .wa-bubble-wrap.out { justify-content: flex-end; }
  .wa-bubble-wrap.in { justify-content: flex-start; }

  .wa-bubble {
    max-width: 65%;
    padding: 6px 8px 4px;
    border-radius: 8px;
    font-size: 14.2px;
    line-height: 1.35;
    color: var(--wa-text);
    position: relative;
    word-wrap: break-word;
    box-shadow: 0 1px 0.5px rgba(0,0,0,0.08);
  }
  .wa-bubble.out {
    background: var(--wa-bubble-out);
    border-top-right-radius: 0;
  }
  .wa-bubble.in {
    background: var(--wa-bubble-in);
    border-top-left-radius: 0;
  }

  .wa-bubble-content { padding-right: 48px; min-width: 80px; }

  .wa-bubble-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    margin-top: -2px;
  }

  .wa-bubble-time {
    font-size: 11px;
    color: var(--wa-text-secondary);
    white-space: nowrap;
    float: right;
    margin-top: 4px;
    margin-left: 8px;
  }

  .wa-bubble-status { font-size: 14px; }
  .wa-bubble-status.read { color: #53bdeb; }
  .wa-bubble-status.delivered { color: var(--wa-text-secondary); }
  .wa-bubble-status.sent { color: var(--wa-text-secondary); }

  .wa-bubble-sender {
    font-size: 12.5px;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .wa-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
    background: rgba(0,0,0,0.06);
    color: var(--wa-text-secondary);
    margin-bottom: 2px;
  }

  .wa-date-divider {
    display: flex;
    justify-content: center;
    margin: 12px 0;
  }
  .wa-date-divider span {
    background: rgba(255,255,255,0.85);
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 12.5px;
    color: var(--wa-text-secondary);
    box-shadow: 0 1px 0.5px rgba(0,0,0,0.08);
  }
  .dark .wa-date-divider span {
    background: rgba(32,44,51,0.9);
  }

  /* ─── Empty state ─── */
  .wa-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--wa-text-secondary);
    background: var(--wa-chat-bg);
  }
  .wa-empty-state svg { opacity: 0.25; }
  .wa-empty-state h3 { font-size: 28px; font-weight: 300; color: var(--wa-text); margin: 0; }
  .wa-empty-state p { font-size: 14px; margin: 0; }

  .wa-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    color: var(--wa-text-secondary);
    font-size: 14px;
  }

  .wa-spinner {
    width: 28px; height: 28px;
    border: 3px solid var(--wa-border);
    border-top-color: var(--wa-green);
    border-radius: 50%;
    animation: wa-spin 0.8s linear infinite;
    margin-right: 10px;
  }
  @keyframes wa-spin { to { transform: rotate(360deg); } }

  .wa-load-more {
    text-align: center;
    padding: 8px;
  }
  .wa-load-more button {
    padding: 6px 16px;
    border: none;
    border-radius: 20px;
    background: rgba(0,0,0,0.06);
    font-size: 13px;
    color: var(--wa-green-dark);
    cursor: pointer;
    transition: background 0.2s;
  }
  .wa-load-more button:hover { background: rgba(0,0,0,0.1); }

  .wa-no-chats {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; flex: 1; gap: 8px;
    color: var(--wa-text-secondary); font-size: 14px;
  }

  /* ─── Message Input ─── */
  .wa-input-area {
    background: var(--wa-header-bg);
    padding: 10px 16px;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    border-top: 1px solid var(--wa-border);
  }

  .wa-input-wrap {
    flex: 1;
    display: flex;
    align-items: flex-end;
    background: var(--wa-sidebar-bg);
    border-radius: 8px;
    border: 1px solid var(--wa-border);
    padding: 6px 12px;
    transition: border-color 0.2s;
  }
  .wa-input-wrap:focus-within { border-color: var(--wa-green); }

  .wa-msg-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--wa-text);
    font-size: 14px;
    line-height: 1.4;
    max-height: 120px;
    resize: none;
    font-family: inherit;
    padding: 4px 0;
  }
  .wa-msg-input::placeholder { color: var(--wa-text-secondary); }

  .wa-send-btn {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: none;
    background: var(--wa-green);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s;
  }
  .wa-send-btn:hover { background: var(--wa-green-dark); transform: scale(1.05); }
  .wa-send-btn:active { transform: scale(0.95); }
  .wa-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .wa-not-connected {
    background: var(--wa-header-bg);
    padding: 12px 16px;
    text-align: center;
    font-size: 13px;
    color: #e11d48;
    border-top: 1px solid var(--wa-border);
  }
</style>

<div class="wa-container" id="waContainer">
  <!-- Sidebar -->
  <div class="wa-sidebar">
    <div class="wa-sidebar-header">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--wa-green)" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <select class="wa-device-select" id="deviceFilter">
        <option value="">All Devices</option>
        <% devices.forEach(d => { %>
          <option value="<%= d.sessionId %>"><%= d.name || d.sessionId %><%= d.phoneNumber ? ` (${d.phoneNumber})` : '' %></option>
        <% }) %>
      </select>
    </div>

    <div class="wa-search-bar">
      <div class="wa-search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" class="wa-search-input" id="chatSearch" placeholder="Search or start new chat">
      </div>
    </div>

    <div class="wa-chat-list" id="chatList">
      <div class="wa-loading"><div class="wa-spinner"></div> Loading chats...</div>
    </div>
  </div>

  <!-- Main chat area -->
  <div class="wa-main" id="waMain">
    <div class="wa-empty-state" id="emptyState">
      <svg width="200" height="200" viewBox="0 0 303 172" fill="currentColor">
        <path d="M229.565 160.229c32.647-16.166 55.388-50.156 55.388-89.428 0-55.178-44.823-99.5-100.5-99.5-40.083 0-74.716 23.346-90.927 57.073C38.815 30.072 0 68.926 0 115.129c0 21.313 7.584 40.875 20.2 56.143l-15.168 23.467c-.563.870-.133 2.033.875 2.37l27.091 9.061c9.477 3.164 19.725-.104 25.907-7.477C72.083 208.074 88.406 213 105.931 213c31.47 0 58.381-19.152 69.888-46.423 12.576 6.736 27.026 10.551 42.284 10.551 13.458 0 26.21-3.082 37.591-8.583l22.193 15.674c.874.617 2.08.076 2.252-.998l3.621-22.594c.104-.648-.261-1.282-.867-1.518-9.17-3.576-17.363-8.802-24.253-15.37-8.654 5.027-18.452 8.496-28.91 10.091l-.165.399z"/>
      </svg>
      <h3>WhatsApp Chat History</h3>
      <p>Select a conversation to view messages</p>
    </div>
  </div>
</div>

<script>
(function() {
  const deviceFilter = document.getElementById('deviceFilter');
  const chatList = document.getElementById('chatList');
  const chatSearch = document.getElementById('chatSearch');
  const waMain = document.getElementById('waMain');
  const emptyState = document.getElementById('emptyState');

  let allChats = [];
  let activeJid = null;
  let activeDevice = null;

  // Device label colors
  const deviceColors = ['#25d366','#6366f1','#e11d48','#f59e0b','#06b6d4','#7c3aed','#128c7e','#075e54','#34b7f1','#00a884'];
  const deviceColorMap = {};
  let colorIdx = 0;
  function getDeviceColor(sessionId) {
    if (!deviceColorMap[sessionId]) {
      deviceColorMap[sessionId] = deviceColors[colorIdx % deviceColors.length];
      colorIdx++;
    }
    return deviceColorMap[sessionId];
  }

  const avatarColors = ['#25d366','#128c7e','#075e54','#34b7f1','#00a884','#7c3aed','#e11d48','#f59e0b','#06b6d4','#6366f1'];
  function getAvatarColor(str) {
    let h = 0;
    for (let i = 0; i < (str||'').length; i++) h = str.charCodeAt(i) + ((h << 5) - h);
    return avatarColors[Math.abs(h) % avatarColors.length];
  }

  function getInitials(name) {
    const parts = (name || '?').split(' ');
    return parts.length > 1 ? (parts[0][0] + parts[1][0]).toUpperCase() : name.substring(0, 2).toUpperCase();
  }

  function formatTime(dateStr) {
    const d = new Date(dateStr);
    const now = new Date();
    const diff = now - d;
    const dayMs = 86400000;
    if (diff < dayMs && d.getDate() === now.getDate()) {
      return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }
    if (diff < 2 * dayMs) return 'Yesterday';
    if (diff < 7 * dayMs) return d.toLocaleDateString([], { weekday: 'short' });
    return d.toLocaleDateString([], { day: '2-digit', month: '2-digit', year: '2-digit' });
  }

  function formatMsgTime(dateStr) {
    return new Date(dateStr).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function formatDate(dateStr) {
    const d = new Date(dateStr);
    const now = new Date();
    const diff = now - d;
    if (diff < 86400000 && d.getDate() === now.getDate()) return 'Today';
    if (diff < 172800000) return 'Yesterday';
    return d.toLocaleDateString([], { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
  }

  function statusIcon(status) {
    if (!status) return '';
    if (status === 'read') return '<span class="wa-bubble-status read">✓✓</span>';
    if (status === 'delivered') return '<span class="wa-bubble-status delivered">✓✓</span>';
    return '<span class="wa-bubble-status sent">✓</span>';
  }

  function typeIcon(type) {
    if (!type || type === 'text' || type === 'conversation' || type === 'extendedTextMessage') return '';
    const icons = { image: '📷', video: '🎥', audio: '🎵', document: '📄', sticker: '🏷️', location: '📍', contact: '👤', poll: '📊' };
    const label = type.replace('Message', '');
    return `<span class="wa-type-badge">${icons[label] || '📎'} ${label}</span>`;
  }

  function escapeHtml(str) {
    const d = document.createElement('div');
    d.textContent = str || '';
    return d.innerHTML;
  }

  // Load chats
  async function loadChats() {
    const device = deviceFilter.value;
    chatList.innerHTML = '<div class="wa-loading"><div class="wa-spinner"></div> Loading chats...</div>';

    try {
      const url = device ? `/chat/api/chats?device=${encodeURIComponent(device)}` : '/chat/api/chats';
      const resp = await fetch(url);
      allChats = await resp.json();
      renderChats(allChats);
    } catch (e) {
      chatList.innerHTML = '<div class="wa-no-chats"><span>Failed to load chats</span></div>';
    }
  }

  function renderChats(chats) {
    if (!chats.length) {
      chatList.innerHTML = '<div class="wa-no-chats"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span>No conversations found</span></div>';
      return;
    }

    chatList.innerHTML = chats.map(chat => {
      const isActive = activeJid === chat.remoteJid && activeDevice === chat.sessionId;
      const deviceLabel = chat.phoneNumber
        ? `${escapeHtml(chat.deviceName)} · ${escapeHtml(chat.phoneNumber)}`
        : escapeHtml(chat.deviceName);

      return `
        <div class="wa-chat-item ${isActive ? 'active' : ''}" data-jid="${chat.remoteJid}" data-device="${chat.sessionId}" onclick="window.__openChat('${chat.sessionId}','${chat.remoteJid}')">
          <div class="wa-avatar" style="background:${getAvatarColor(chat.remoteJid)}">
            ${chat.isGroup ? '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' : getInitials(chat.name)}
          </div>
          <div class="wa-chat-info">
            <div class="wa-chat-name-row">
              <span class="wa-chat-name">${escapeHtml(chat.name)}</span>
              <span class="wa-device-label" style="background:${getDeviceColor(chat.sessionId)}">${deviceLabel}</span>
            </div>
            <div class="wa-chat-preview">${escapeHtml(chat.lastMessage)}</div>
          </div>
          <div class="wa-chat-meta">
            <span class="wa-chat-time">${formatTime(chat.time)}</span>
            ${chat.totalMessages > 0 ? `<span class="wa-chat-badge">${chat.totalMessages}</span>` : ''}
          </div>
        </div>
      `;
    }).join('');
  }

  // Load messages for a chat
  // Check if device is connected
  function isDeviceConnected(sessionId) {
    const devices = <%- JSON.stringify(devices) %>;
    const d = devices.find(d => d.sessionId === sessionId);
    return d && d.status === 'connected';
  }

  window.__openChat = async function(device, jid) {
    activeJid = jid;
    activeDevice = device;
    const chat = allChats.find(c => c.remoteJid === jid && c.sessionId === device);

    // Update active state in sidebar
    document.querySelectorAll('.wa-chat-item').forEach(el => {
      el.classList.toggle('active', el.dataset.jid === jid && el.dataset.device === device);
    });

    const name = chat ? chat.name : jid.split('@')[0];
    const isGroup = jid.includes('@g.us');
    const color = getAvatarColor(jid);
    const deviceLabel = chat ? (chat.phoneNumber ? `${chat.deviceName} · ${chat.phoneNumber}` : chat.deviceName) : device;
    const connected = isDeviceConnected(device);

    waMain.innerHTML = `
      <div class="wa-main-header">
        <div class="wa-avatar" style="background:${color};width:40px;height:40px;font-size:15px">
          ${isGroup ? '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' : getInitials(name)}
        </div>
        <div class="wa-chat-info">
          <div class="wa-chat-name-row">
            <span class="wa-chat-name">${escapeHtml(name)}</span>
            <span class="wa-device-label" style="background:${getDeviceColor(device)}">${escapeHtml(deviceLabel)}</span>
          </div>
          <div class="wa-chat-preview">${isGroup ? 'Group' : jid.split('@')[0]}</div>
        </div>
      </div>
      <div class="wa-messages-area" id="msgArea">
        <div class="wa-loading"><div class="wa-spinner"></div> Loading messages...</div>
      </div>
      ${connected ? `
        <div class="wa-input-area">
          <div class="wa-input-wrap">
            <textarea class="wa-msg-input" id="msgInput" placeholder="Type a message" rows="1"></textarea>
          </div>
          <button class="wa-send-btn" id="sendBtn" onclick="window.__sendMessage()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </div>
      ` : `
        <div class="wa-not-connected">⚠ Device is not connected. Messages are read-only.</div>
      `}
    `;

    // Auto-resize textarea
    const input = document.getElementById('msgInput');
    if (input) {
      input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          window.__sendMessage();
        }
      });
      input.focus();
    }

    await loadMessages(device, jid, 1, true);
  };

  async function loadMessages(device, jid, page, scroll) {
    try {
      const resp = await fetch(`/chat/api/messages?device=${encodeURIComponent(device)}&jid=${encodeURIComponent(jid)}&page=${page}`);
      const data = await resp.json();
      const msgArea = document.getElementById('msgArea');

      if (page === 1) msgArea.innerHTML = '';

      if (data.hasMore) {
        const loadMoreDiv = document.createElement('div');
        loadMoreDiv.className = 'wa-load-more';
        loadMoreDiv.innerHTML = `<button onclick="window.__loadMore(${page + 1})">↑ Load older messages</button>`;
        msgArea.prepend(loadMoreDiv);
      }

      if (!data.messages.length && page === 1) {
        msgArea.innerHTML = '<div class="wa-no-chats"><span>No messages yet</span></div>';
        return;
      }

      let lastDate = null;
      const fragment = document.createDocumentFragment();

      data.messages.forEach(msg => {
        const msgDate = formatDate(msg.createdAt);
        if (msgDate !== lastDate) {
          lastDate = msgDate;
          const divider = document.createElement('div');
          divider.className = 'wa-date-divider';
          divider.innerHTML = `<span>${msgDate}</span>`;
          fragment.appendChild(divider);
        }

        const wrap = document.createElement('div');
        wrap.className = `wa-bubble-wrap ${msg.fromMe ? 'out' : 'in'}`;
        
        const typeHtml = typeIcon(msg.messageType);
        const content = escapeHtml(msg.content) || `[${msg.messageType}]`;

        wrap.innerHTML = `
          <div class="wa-bubble ${msg.fromMe ? 'out' : 'in'}">
            ${!msg.fromMe && msg.pushName ? `<div class="wa-bubble-sender" style="color:${getAvatarColor(msg.pushName)}">${escapeHtml(msg.pushName)}</div>` : ''}
            ${typeHtml}
            <div class="wa-bubble-content">${content}</div>
            <span class="wa-bubble-time">
              ${formatMsgTime(msg.createdAt)}
              ${msg.fromMe ? statusIcon(msg.status) : ''}
            </span>
          </div>
        `;
        fragment.appendChild(wrap);
      });

      msgArea.appendChild(fragment);
      if (scroll) msgArea.scrollTop = msgArea.scrollHeight;
    } catch (e) {
      console.error('loadMessages error:', e);
    }
  }

  window.__loadMore = async function(page) {
    const btn = document.querySelector('.wa-load-more');
    if (btn) btn.remove();
    await loadMessages(activeDevice, activeJid, page, false);
  };

  // Send message
  window.__sendMessage = async function() {
    const input = document.getElementById('msgInput');
    const btn = document.getElementById('sendBtn');
    if (!input || !activeDevice || !activeJid) return;

    const text = input.value.trim();
    if (!text) return;

    // Disable while sending
    input.disabled = true;
    btn.disabled = true;
    input.value = '';
    input.style.height = 'auto';

    // Optimistic: show message immediately
    const msgArea = document.getElementById('msgArea');
    const wrap = document.createElement('div');
    wrap.className = 'wa-bubble-wrap out';
    wrap.innerHTML = `
      <div class="wa-bubble out">
        <div class="wa-bubble-content">${escapeHtml(text)}</div>
        <span class="wa-bubble-time">
          ${formatMsgTime(new Date().toISOString())}
          <span class="wa-bubble-status sent">✓</span>
        </span>
      </div>
    `;
    msgArea.appendChild(wrap);
    msgArea.scrollTop = msgArea.scrollHeight;

    try {
      const resp = await fetch('/chat/api/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ device: activeDevice, jid: activeJid, text }),
      });
      const data = await resp.json();
      if (!data.success) {
        wrap.querySelector('.wa-bubble').style.opacity = '0.5';
        wrap.querySelector('.wa-bubble-status').textContent = '✗';
        wrap.querySelector('.wa-bubble-status').style.color = '#e11d48';
      } else {
        wrap.querySelector('.wa-bubble-status').textContent = '✓✓';
      }
    } catch (e) {
      wrap.querySelector('.wa-bubble').style.opacity = '0.5';
      wrap.querySelector('.wa-bubble-status').textContent = '✗';
      wrap.querySelector('.wa-bubble-status').style.color = '#e11d48';
    }

    input.disabled = false;
    btn.disabled = false;
    input.focus();
  };

  // Device filter change
  deviceFilter.addEventListener('change', () => {
    activeJid = null;
    activeDevice = null;
    waMain.innerHTML = emptyState.outerHTML;
    loadChats();
  });

  // Search
  chatSearch.addEventListener('input', () => {
    const q = chatSearch.value.toLowerCase();
    if (!q) return renderChats(allChats);
    renderChats(allChats.filter(c =>
      c.name.toLowerCase().includes(q) ||
      c.remoteJid.toLowerCase().includes(q) ||
      (c.lastMessage || '').toLowerCase().includes(q) ||
      (c.deviceName || '').toLowerCase().includes(q) ||
      (c.phoneNumber || '').toLowerCase().includes(q)
    ));
  });

  // Load all chats on page load
  loadChats();
})();
</script>
