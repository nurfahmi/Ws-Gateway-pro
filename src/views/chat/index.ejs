<style>
  .main-content { padding: 0 !important; }
  
  :root {
    --wa-green: #00a884; --wa-green-dark: #008069;
    --wa-bg: #efeae2; --wa-sidebar-bg: #ffffff; --wa-header-bg: #f0f2f5;
    --wa-chat-bg: #efeae2; --wa-bubble-out: #d9fdd3; --wa-bubble-in: #ffffff;
    --wa-text: #111b21; --wa-text-secondary: #667781; --wa-border: #e9edef;
    --wa-hover: #f5f6f6; --wa-search-bg: #f0f2f5; --wa-doodle: rgba(0,0,0,0.03);
  }
  .dark {
    --wa-green: #00a884; --wa-green-dark: #00a884;
    --wa-bg: #0b141a; --wa-sidebar-bg: #111b21; --wa-header-bg: #202c33;
    --wa-chat-bg: #0b141a; --wa-bubble-out: #005c4b; --wa-bubble-in: #202c33;
    --wa-text: #e9edef; --wa-text-secondary: #8696a0; --wa-border: #2a3942;
    --wa-hover: #202c33; --wa-search-bg: #202c33; --wa-doodle: rgba(255,255,255,0.03);
  }

  .wa-container { display: flex; height: calc(100vh - 56px); background: var(--wa-bg); overflow: hidden; }

  .wa-sidebar { width: 420px; min-width: 320px; max-width: 420px; background: var(--wa-sidebar-bg); border-right: 1px solid var(--wa-border); display: flex; flex-direction: column; }
  .wa-sidebar-header { background: var(--wa-header-bg); padding: 10px 16px; display: flex; align-items: center; gap: 12px; min-height: 56px; border-bottom: 1px solid var(--wa-border); }
  .wa-device-select { flex: 1; padding: 8px 12px; border: 1px solid var(--wa-border); border-radius: 8px; background: var(--wa-sidebar-bg); color: var(--wa-text); font-size: 14px; outline: none; cursor: pointer; }
  .wa-device-select:focus { border-color: var(--wa-green); }

  .wa-search-bar { padding: 8px 12px; background: var(--wa-sidebar-bg); border-bottom: 1px solid var(--wa-border); }
  .wa-search-wrap { position: relative; }
  .wa-search-wrap svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--wa-text-secondary); }
  .wa-search-input { width: 100%; padding: 8px 12px 8px 36px; border: none; border-radius: 8px; background: var(--wa-search-bg); color: var(--wa-text); font-size: 13.5px; outline: none; }
  .wa-search-input::placeholder { color: var(--wa-text-secondary); }

  .wa-chat-list { flex: 1; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.15) transparent; }

  .wa-chat-item { display: flex; align-items: center; padding: 10px 16px; gap: 14px; cursor: pointer; transition: background 0.15s; border-bottom: 1px solid var(--wa-border); }
  .wa-chat-item:hover { background: var(--wa-hover); }
  .wa-chat-item.active { background: var(--wa-hover); }

  .wa-avatar { width: 48px; height: 48px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 18px; color: #fff; }
  .wa-chat-info { flex: 1; min-width: 0; }
  .wa-chat-name-row { display: flex; align-items: center; gap: 6px; }
  .wa-chat-name { font-size: 16px; font-weight: 400; color: var(--wa-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .wa-device-label { display: inline-flex; padding: 1px 6px; border-radius: 4px; font-size: 10px; font-weight: 600; background: var(--wa-green); color: #fff; white-space: nowrap; flex-shrink: 0; max-width: 120px; overflow: hidden; text-overflow: ellipsis; }
  .wa-chat-preview { font-size: 13px; color: var(--wa-text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
  .wa-chat-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
  .wa-chat-time { font-size: 12px; color: var(--wa-text-secondary); white-space: nowrap; }
  .wa-chat-badge { background: var(--wa-green); color: #fff; font-size: 11px; font-weight: 600; min-width: 20px; height: 20px; border-radius: 20px; display: flex; align-items: center; justify-content: center; padding: 0 5px; }

  .wa-main { flex: 1; display: flex; flex-direction: column; background: var(--wa-chat-bg); position: relative; }
  .wa-main-header { background: var(--wa-header-bg); padding: 10px 16px; display: flex; align-items: center; gap: 14px; min-height: 56px; border-bottom: 1px solid var(--wa-border); }
  .wa-main-header .wa-chat-name { font-size: 16px; font-weight: 500; }
  .wa-main-header .wa-chat-preview { font-size: 13px; margin-top: 0; }

  .wa-messages-area { flex: 1; overflow-y: auto; padding: 20px 60px; display: flex; flex-direction: column; gap: 2px; background-image: radial-gradient(circle at 20% 30%, var(--wa-doodle) 1px, transparent 1px), radial-gradient(circle at 80% 70%, var(--wa-doodle) 1px, transparent 1px); background-size: 40px 40px; scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.15) transparent; }

  .wa-bubble-wrap { display: flex; margin-bottom: 2px; }
  .wa-bubble-wrap.out { justify-content: flex-end; }
  .wa-bubble-wrap.in { justify-content: flex-start; }
  .wa-bubble { max-width: 65%; padding: 6px 8px 4px; border-radius: 8px; font-size: 14.2px; line-height: 1.35; color: var(--wa-text); position: relative; word-wrap: break-word; box-shadow: 0 1px 0.5px rgba(0,0,0,0.08); }
  .wa-bubble.out { background: var(--wa-bubble-out); border-top-right-radius: 0; }
  .wa-bubble.in { background: var(--wa-bubble-in); border-top-left-radius: 0; }
  .wa-bubble-content { padding-right: 48px; min-width: 80px; }
  .wa-bubble-time { font-size: 11px; color: var(--wa-text-secondary); white-space: nowrap; float: right; margin-top: 4px; margin-left: 8px; }
  .wa-bubble-status { font-size: 14px; }
  .wa-bubble-status.read { color: #53bdeb; }
  .wa-bubble-sender { font-size: 12.5px; font-weight: 500; margin-bottom: 2px; }

  .wa-date-divider { display: flex; justify-content: center; margin: 12px 0; }
  .wa-date-divider span { background: rgba(255,255,255,0.85); padding: 5px 12px; border-radius: 8px; font-size: 12.5px; color: var(--wa-text-secondary); box-shadow: 0 1px 0.5px rgba(0,0,0,0.08); }
  .dark .wa-date-divider span { background: rgba(32,44,51,0.9); }

  .wa-media-placeholder { display: flex; align-items: center; gap: 6px; padding: 8px 12px; border-radius: 6px; background: rgba(0,0,0,0.05); font-size: 13px; color: var(--wa-text-secondary); margin-bottom: 4px; }
  .dark .wa-media-placeholder { background: rgba(255,255,255,0.05); }
  .wa-media-placeholder span { font-weight: 500; }
  .wa-media-caption { font-size: 14px; color: var(--wa-text); margin-top: 4px; line-height: 1.35; }

  .wa-empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; color: var(--wa-text-secondary); background: var(--wa-chat-bg); }
  .wa-empty-state svg { opacity: 0.25; }
  .wa-empty-state h3 { font-size: 28px; font-weight: 300; color: var(--wa-text); margin: 0; }
  .wa-empty-state p { font-size: 14px; margin: 0; }

  .wa-loading { display: flex; align-items: center; justify-content: center; padding: 40px; color: var(--wa-text-secondary); font-size: 14px; }
  .wa-spinner { width: 28px; height: 28px; border: 3px solid var(--wa-border); border-top-color: var(--wa-green); border-radius: 50%; animation: wa-spin 0.8s linear infinite; margin-right: 10px; }
  @keyframes wa-spin { to { transform: rotate(360deg); } }

  .wa-load-more { text-align: center; padding: 8px; }
  .wa-load-more button { padding: 6px 16px; border: none; border-radius: 20px; background: rgba(0,0,0,0.06); font-size: 13px; color: var(--wa-green-dark); cursor: pointer; }
  .wa-load-more button:hover { background: rgba(0,0,0,0.1); }
  .wa-no-chats { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; gap: 8px; color: var(--wa-text-secondary); font-size: 14px; }

  /* Input area */
  .wa-input-area { background: var(--wa-header-bg); padding: 10px 16px; display: flex; align-items: flex-end; gap: 10px; border-top: 1px solid var(--wa-border); }
  .wa-input-wrap { flex: 1; display: flex; align-items: flex-end; background: var(--wa-sidebar-bg); border-radius: 8px; border: 1px solid var(--wa-border); padding: 6px 12px; transition: border-color 0.2s; }
  .wa-input-wrap:focus-within { border-color: var(--wa-green); }
  .wa-msg-input { flex: 1; border: none; outline: none; background: transparent; color: var(--wa-text); font-size: 14px; line-height: 1.4; max-height: 120px; resize: none; font-family: inherit; padding: 4px 0; }
  .wa-msg-input::placeholder { color: var(--wa-text-secondary); }

  .wa-btn { width: 42px; height: 42px; border-radius: 50%; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s, transform 0.15s; }
  .wa-send-btn { background: var(--wa-green); color: #fff; }
  .wa-send-btn:hover { background: var(--wa-green-dark); transform: scale(1.05); }
  .wa-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .wa-attach-btn { background: transparent; color: var(--wa-text-secondary); }
  .wa-attach-btn:hover { background: var(--wa-hover); color: var(--wa-text); }

  .wa-not-connected { background: var(--wa-header-bg); padding: 12px 16px; text-align: center; font-size: 13px; color: #e11d48; border-top: 1px solid var(--wa-border); }

  .wa-preview-bar { background: var(--wa-header-bg); padding: 8px 16px; display: flex; align-items: center; gap: 10px; border-top: 1px solid var(--wa-border); }
  .wa-preview-img { width: 48px; height: 48px; border-radius: 6px; object-fit: cover; }
  .wa-preview-name { flex: 1; font-size: 13px; color: var(--wa-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wa-preview-remove { background: none; border: none; color: #e11d48; cursor: pointer; font-size: 18px; padding: 4px 8px; }
</style>

<div class="wa-container">
  <div class="wa-sidebar">
    <div class="wa-sidebar-header">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--wa-green)" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <select class="wa-device-select" id="deviceFilter">
        <option value="">All Devices</option>
        <% devices.forEach(d => { %>
          <option value="<%= d.sessionId %>" data-status="<%= d.status %>"><%= d.name || d.sessionId %><%= d.phoneNumber ? ` (${d.phoneNumber})` : '' %></option>
        <% }) %>
      </select>
    </div>
    <div class="wa-search-bar">
      <div class="wa-search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" class="wa-search-input" id="chatSearch" placeholder="Search or start new chat">
      </div>
    </div>
    <div class="wa-chat-list" id="chatList">
      <div class="wa-loading"><div class="wa-spinner"></div> Loading chats...</div>
    </div>
  </div>

  <div class="wa-main" id="waMain">
    <div class="wa-empty-state" id="emptyState">
      <svg width="200" height="200" viewBox="0 0 303 172" fill="currentColor"><path d="M229.565 160.229c32.647-16.166 55.388-50.156 55.388-89.428 0-55.178-44.823-99.5-100.5-99.5-40.083 0-74.716 23.346-90.927 57.073C38.815 30.072 0 68.926 0 115.129c0 21.313 7.584 40.875 20.2 56.143l-15.168 23.467c-.563.870-.133 2.033.875 2.37l27.091 9.061c9.477 3.164 19.725-.104 25.907-7.477C72.083 208.074 88.406 213 105.931 213c31.47 0 58.381-19.152 69.888-46.423 12.576 6.736 27.026 10.551 42.284 10.551 13.458 0 26.21-3.082 37.591-8.583l22.193 15.674c.874.617 2.08.076 2.252-.998l3.621-22.594c.104-.648-.261-1.282-.867-1.518-9.17-3.576-17.363-8.802-24.253-15.37-8.654 5.027-18.452 8.496-28.91 10.091l-.165.399z"/></svg>
      <h3>WhatsApp Chat</h3>
      <p>Select a conversation to start chatting</p>
    </div>
  </div>
</div>

<input type="file" id="fileInput" accept="image/*,video/mp4,.pdf,.doc,.docx" hidden>

<script src="/socket.io/socket.io.js"></script>
<script>
(function() {
  const socket = io();
  const deviceFilter = document.getElementById('deviceFilter');
  const chatList = document.getElementById('chatList');
  const chatSearch = document.getElementById('chatSearch');
  const waMain = document.getElementById('waMain');
  const emptyState = document.getElementById('emptyState');
  const fileInput = document.getElementById('fileInput');

  let allChats = [];
  let activeJid = null;
  let activeDevice = null;
  let lastMsgId = 0;
  let pendingFile = null;

  const devices = <%- JSON.stringify(devices) %>;

  const deviceColors = ['#25d366','#6366f1','#e11d48','#f59e0b','#06b6d4','#7c3aed','#128c7e','#075e54','#34b7f1','#00a884'];
  const deviceColorMap = {};
  let colorIdx = 0;
  function getDeviceColor(sid) { if (!deviceColorMap[sid]) { deviceColorMap[sid] = deviceColors[colorIdx++ % deviceColors.length]; } return deviceColorMap[sid]; }

  const avatarColors = ['#25d366','#128c7e','#075e54','#34b7f1','#00a884','#7c3aed','#e11d48','#f59e0b','#06b6d4','#6366f1'];
  function getAvatarColor(s) { let h=0; for(let i=0;i<(s||'').length;i++) h=s.charCodeAt(i)+((h<<5)-h); return avatarColors[Math.abs(h)%avatarColors.length]; }
  function getInitials(n) { const p=(n||'?').split(' '); return p.length>1?(p[0][0]+p[1][0]).toUpperCase():n.substring(0,2).toUpperCase(); }
  function esc(s) { const d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }

  function formatTime(ds) { const d=new Date(ds),n=new Date(),diff=n-d; if(diff<86400000&&d.getDate()===n.getDate()) return d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}); if(diff<172800000) return 'Yesterday'; if(diff<604800000) return d.toLocaleDateString([],{weekday:'short'}); return d.toLocaleDateString([],{day:'2-digit',month:'2-digit',year:'2-digit'}); }
  function fmtTime(ds) { return new Date(ds).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}); }
  function fmtDate(ds) { const d=new Date(ds),n=new Date(),diff=n-d; if(diff<86400000&&d.getDate()===n.getDate()) return 'Today'; if(diff<172800000) return 'Yesterday'; return d.toLocaleDateString([],{weekday:'long',day:'numeric',month:'long',year:'numeric'}); }

  function statusIcon(s) { if(!s) return ''; if(s==='read') return '<span class="wa-bubble-status read">✓✓</span>'; if(s==='delivered') return '<span class="wa-bubble-status">✓✓</span>'; return '<span class="wa-bubble-status">✓</span>'; }

  function isConnected(sid) { const d = devices.find(x => x.sessionId === sid); return d && d.status === 'connected'; }

  function mediaHtml(mt, content) {
    if(mt==='image') { let h='<div class="wa-media-placeholder">📷 <span>Photo</span></div>'; if(content) h+=`<div class="wa-media-caption">${esc(content)}</div>`; return h; }
    if(mt==='video') { let h='<div class="wa-media-placeholder">🎥 <span>Video</span></div>'; if(content) h+=`<div class="wa-media-caption">${esc(content)}</div>`; return h; }
    if(mt==='audio'||mt==='ptt') return '<div class="wa-media-placeholder">� <span>Audio</span></div>';
    if(mt==='document') return `<div class="wa-media-placeholder">📄 <span>${esc(content)||'Document'}</span></div>`;
    if(mt==='sticker') return '<div class="wa-media-placeholder">🏷️ <span>Sticker</span></div>';
    if(mt==='location'||mt==='liveLocationMessage') return '<div class="wa-media-placeholder">📍 <span>Location</span></div>';
    if(mt==='contactMessage'||mt==='contactsArrayMessage') return '<div class="wa-media-placeholder">👤 <span>Contact</span></div>';
    return esc(content) || `[${mt}]`;
  }

  function makeBubble(msg) {
    const wrap = document.createElement('div');
    wrap.className = `wa-bubble-wrap ${msg.fromMe ? 'out' : 'in'}`;
    wrap.dataset.msgId = msg.id || '';
    wrap.innerHTML = `
      <div class="wa-bubble ${msg.fromMe ? 'out' : 'in'}">
        ${!msg.fromMe && msg.pushName ? `<div class="wa-bubble-sender" style="color:${getAvatarColor(msg.pushName)}">${esc(msg.pushName)}</div>` : ''}
        <div class="wa-bubble-content">${mediaHtml(msg.messageType||'text', msg.content)}</div>
        <span class="wa-bubble-time">${fmtTime(msg.createdAt)} ${msg.fromMe ? statusIcon(msg.status) : ''}</span>
      </div>`;
    return wrap;
  }

  // ─── Chat List ───
  async function loadChats() {
    const dev = deviceFilter.value;
    chatList.innerHTML = '<div class="wa-loading"><div class="wa-spinner"></div> Loading...</div>';
    try {
      const url = dev ? `/chat/api/chats?device=${encodeURIComponent(dev)}` : '/chat/api/chats';
      const r = await fetch(url);
      allChats = await r.json();
      renderChats(allChats);
    } catch(e) { chatList.innerHTML = '<div class="wa-no-chats"><span>Failed to load</span></div>'; }
  }

  function renderChats(chats) {
    if(!chats.length) { chatList.innerHTML = '<div class="wa-no-chats"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span>No conversations found</span></div>'; return; }
    chatList.innerHTML = chats.map(c => {
      const active = activeJid===c.remoteJid && activeDevice===c.sessionId;
      const dl = c.phoneNumber ? `${esc(c.deviceName)} · ${esc(c.phoneNumber)}` : esc(c.deviceName);
      return `
        <div class="wa-chat-item ${active?'active':''}" data-jid="${c.remoteJid}" data-device="${c.sessionId}" onclick="window.__open('${c.sessionId}','${c.remoteJid}')">
          <div class="wa-avatar" style="background:${getAvatarColor(c.remoteJid)}">${c.isGroup?'<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>':getInitials(c.name)}</div>
          <div class="wa-chat-info">
            <div class="wa-chat-name-row"><span class="wa-chat-name">${esc(c.name)}</span><span class="wa-device-label" style="background:${getDeviceColor(c.sessionId)}">${dl}</span></div>
            <div class="wa-chat-preview">${esc(c.lastMessage)}</div>
          </div>
          <div class="wa-chat-meta">
            <span class="wa-chat-time">${formatTime(c.time)}</span>
            ${c.totalMessages>0?`<span class="wa-chat-badge">${c.totalMessages}</span>`:''}
          </div>
        </div>`;
    }).join('');
  }

  // ─── Open Chat ───
  window.__open = async function(dev, jid) {
    activeJid = jid; activeDevice = dev; lastMsgId = 0; pendingFile = null;
    const chat = allChats.find(c => c.remoteJid===jid && c.sessionId===dev);
    document.querySelectorAll('.wa-chat-item').forEach(el => el.classList.toggle('active', el.dataset.jid===jid && el.dataset.device===dev));

    const name = chat ? chat.name : jid.split('@')[0];
    const isGroup = jid.includes('@g.us');
    const color = getAvatarColor(jid);
    const dl = chat ? (chat.phoneNumber ? `${chat.deviceName} · ${chat.phoneNumber}` : chat.deviceName) : dev;
    const conn = isConnected(dev);

    waMain.innerHTML = `
      <div class="wa-main-header">
        <div class="wa-avatar" style="background:${color};width:40px;height:40px;font-size:15px">${isGroup?'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>':getInitials(name)}</div>
        <div class="wa-chat-info">
          <div class="wa-chat-name-row"><span class="wa-chat-name">${esc(name)}</span><span class="wa-device-label" style="background:${getDeviceColor(dev)}">${esc(dl)}</span></div>
          <div class="wa-chat-preview">${isGroup?'Group':jid.split('@')[0]}</div>
        </div>
      </div>
      <div class="wa-messages-area" id="msgArea"><div class="wa-loading"><div class="wa-spinner"></div> Loading...</div></div>
      <div id="previewBar"></div>
      ${conn ? `
        <div class="wa-input-area">
          <button class="wa-btn wa-attach-btn" id="attachBtn" title="Attach file">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          </button>
          <div class="wa-input-wrap">
            <textarea class="wa-msg-input" id="msgInput" placeholder="Type a message" rows="1"></textarea>
          </div>
          <button class="wa-btn wa-send-btn" id="sendBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </div>
      ` : '<div class="wa-not-connected">⚠ Device not connected. Read-only mode.</div>'}
    `;

    // Bind events
    const input = document.getElementById('msgInput');
    const sendBtn = document.getElementById('sendBtn');
    const attachBtn = document.getElementById('attachBtn');

    if (input) {
      input.addEventListener('input', () => { input.style.height='auto'; input.style.height=Math.min(input.scrollHeight,120)+'px'; });
      input.addEventListener('keydown', e => { if(e.key==='Enter'&&!e.shiftKey) { e.preventDefault(); doSend(); } });
      input.focus();
    }
    if (sendBtn) sendBtn.addEventListener('click', doSend);
    if (attachBtn) attachBtn.addEventListener('click', () => fileInput.click());

    await loadMessages(dev, jid, 1, true);
  };

  // ─── Load Messages ───
  async function loadMessages(dev, jid, page, scroll) {
    try {
      const r = await fetch(`/chat/api/messages?device=${encodeURIComponent(dev)}&jid=${encodeURIComponent(jid)}&page=${page}`);
      if (!r.ok) { document.getElementById('msgArea').innerHTML = '<div class="wa-no-chats"><span>Failed to load</span></div>'; return; }
      const data = await r.json();
      const msgArea = document.getElementById('msgArea');
      if (!data.messages || !data.messages.length) { if (page===1) msgArea.innerHTML = '<div class="wa-no-chats"><span>No messages yet</span></div>'; return; }
      if (page===1) msgArea.innerHTML = '';
      if (data.hasMore) { const d=document.createElement('div'); d.className='wa-load-more'; d.innerHTML=`<button onclick="window.__more(${page+1})">↑ Load older</button>`; msgArea.prepend(d); }

      let lastDate = null;
      const frag = document.createDocumentFragment();
      data.messages.forEach(msg => {
        const md = fmtDate(msg.createdAt);
        if (md !== lastDate) { lastDate=md; const dv=document.createElement('div'); dv.className='wa-date-divider'; dv.innerHTML=`<span>${md}</span>`; frag.appendChild(dv); }
        frag.appendChild(makeBubble(msg));
      });
      msgArea.appendChild(frag);
      if (scroll) msgArea.scrollTop = msgArea.scrollHeight;
      if (data.messages.length) { const mx = Math.max(...data.messages.map(m=>m.id)); if(mx>lastMsgId) lastMsgId=mx; }
    } catch(e) { console.error('loadMessages error:', e); }
  }

  window.__more = async function(p) { const b=document.querySelector('.wa-load-more'); if(b) b.remove(); await loadMessages(activeDevice,activeJid,p,false); };

  // ─── Send Text ───
  async function doSend() {
    const input = document.getElementById('msgInput');
    const sendBtn = document.getElementById('sendBtn');
    if (!input || !activeDevice || !activeJid) return;

    // If there's a pending file, send media
    if (pendingFile) { await doSendMedia(); return; }

    const text = input.value.trim();
    if (!text) return;
    input.disabled = true; sendBtn.disabled = true;
    input.value = ''; input.style.height = 'auto';

    // Optimistic bubble
    const msgArea = document.getElementById('msgArea');
    const wrap = document.createElement('div');
    wrap.className = 'wa-bubble-wrap out';
    wrap.innerHTML = `<div class="wa-bubble out"><div class="wa-bubble-content">${esc(text)}</div><span class="wa-bubble-time">${fmtTime(new Date().toISOString())} <span class="wa-bubble-status">✓</span></span></div>`;
    msgArea.appendChild(wrap);
    msgArea.scrollTop = msgArea.scrollHeight;

    try {
      const r = await fetch('/chat/api/send', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({device:activeDevice,jid:activeJid,text}) });
      const d = await r.json();
      if (d.success) wrap.querySelector('.wa-bubble-status').textContent = '✓✓';
      else { wrap.querySelector('.wa-bubble').style.opacity='0.5'; wrap.querySelector('.wa-bubble-status').textContent='✗'; wrap.querySelector('.wa-bubble-status').style.color='#e11d48'; }
    } catch(e) { wrap.querySelector('.wa-bubble').style.opacity='0.5'; wrap.querySelector('.wa-bubble-status').textContent='✗'; }
    input.disabled = false; sendBtn.disabled = false; input.focus();
  }

  // ─── Send Media ───
  async function doSendMedia() {
    const input = document.getElementById('msgInput');
    const sendBtn = document.getElementById('sendBtn');
    if (!pendingFile || !activeDevice || !activeJid) return;

    const caption = input ? input.value.trim() : '';
    input.disabled = true; sendBtn.disabled = true;
    input.value = ''; input.style.height = 'auto';

    // Optimistic bubble
    const msgArea = document.getElementById('msgArea');
    const wrap = document.createElement('div');
    wrap.className = 'wa-bubble-wrap out';
    const isImg = pendingFile.type.startsWith('image/');
    const isVid = pendingFile.type.startsWith('video/');
    const icon = isImg ? '📷 Photo' : isVid ? '🎥 Video' : '📄 '+pendingFile.name;
    wrap.innerHTML = `<div class="wa-bubble out"><div class="wa-bubble-content"><div class="wa-media-placeholder">${icon}</div>${caption?`<div class="wa-media-caption">${esc(caption)}</div>`:''}</div><span class="wa-bubble-time">${fmtTime(new Date().toISOString())} <span class="wa-bubble-status">⏳</span></span></div>`;
    msgArea.appendChild(wrap);
    msgArea.scrollTop = msgArea.scrollHeight;

    const fd = new FormData();
    fd.append('file', pendingFile);
    fd.append('device', activeDevice);
    fd.append('jid', activeJid);
    if (caption) fd.append('caption', caption);

    clearPreview();

    try {
      const r = await fetch('/chat/api/send-media', { method:'POST', body: fd });
      const d = await r.json();
      if (d.success) wrap.querySelector('.wa-bubble-status').textContent = '✓✓';
      else { wrap.querySelector('.wa-bubble').style.opacity='0.5'; wrap.querySelector('.wa-bubble-status').textContent='✗'; wrap.querySelector('.wa-bubble-status').style.color='#e11d48'; }
    } catch(e) { wrap.querySelector('.wa-bubble').style.opacity='0.5'; wrap.querySelector('.wa-bubble-status').textContent='✗'; }
    input.disabled = false; sendBtn.disabled = false; input.focus();
  }

  // ─── File Attach ───
  fileInput.addEventListener('change', () => {
    const f = fileInput.files[0];
    if (!f) return;
    pendingFile = f;
    fileInput.value = '';

    const bar = document.getElementById('previewBar');
    if (!bar) return;
    const isImg = f.type.startsWith('image/');
    bar.innerHTML = `
      <div class="wa-preview-bar">
        ${isImg ? `<img class="wa-preview-img" src="${URL.createObjectURL(f)}">` : ''}
        <span class="wa-preview-name">${isImg?'📷':'📄'} ${esc(f.name)} (${(f.size/1024).toFixed(0)} KB)</span>
        <button class="wa-preview-remove" onclick="window.__clearPreview()">✕</button>
      </div>`;
    const input = document.getElementById('msgInput');
    if (input) { input.placeholder = 'Add a caption...'; input.focus(); }
  });

  function clearPreview() { pendingFile=null; const b=document.getElementById('previewBar'); if(b) b.innerHTML=''; const i=document.getElementById('msgInput'); if(i) i.placeholder='Type a message'; }
  window.__clearPreview = clearPreview;

  // ─── Device Filter ───
  deviceFilter.addEventListener('change', () => { activeJid=null; activeDevice=null; waMain.innerHTML=emptyState.outerHTML; loadChats(); });

  // ─── Search ───
  chatSearch.addEventListener('input', () => {
    const q = chatSearch.value.toLowerCase();
    if (!q) return renderChats(allChats);
    renderChats(allChats.filter(c => c.name.toLowerCase().includes(q) || c.remoteJid.toLowerCase().includes(q) || (c.lastMessage||'').toLowerCase().includes(q) || (c.deviceName||'').toLowerCase().includes(q) || (c.phoneNumber||'').toLowerCase().includes(q)));
  });

  // ─── Socket.IO Real-time ───
  socket.on('new-message', msg => {
    // Update chat list
    const chatIdx = allChats.findIndex(c => c.sessionId===msg.sessionId && c.remoteJid===msg.remoteJid);
    if (chatIdx >= 0) {
      allChats[chatIdx].lastMessage = msg.fromMe ? `You: ${msg.content||`[${msg.messageType}]`}` : (msg.content||`[${msg.messageType}]`);
      allChats[chatIdx].time = msg.createdAt;
      allChats[chatIdx].totalMessages++;
      // Move to top
      const [item] = allChats.splice(chatIdx, 1);
      allChats.unshift(item);
    } else {
      allChats.unshift({
        sessionId: msg.sessionId, remoteJid: msg.remoteJid,
        name: msg.pushName || msg.remoteJid?.split('@')[0] || 'Unknown',
        deviceName: msg.sessionId, phoneNumber: null,
        lastMessage: msg.content || `[${msg.messageType}]`,
        messageType: msg.messageType, time: msg.createdAt,
        totalMessages: 1, isGroup: msg.remoteJid?.includes('@g.us') || false,
      });
    }
    if (!chatSearch.value) renderChats(allChats);

    // Append to active chat if matching
    if (activeDevice===msg.sessionId && activeJid===msg.remoteJid && msg.id > lastMsgId) {
      lastMsgId = msg.id;
      const msgArea = document.getElementById('msgArea');
      if (!msgArea) return;
      const atBottom = msgArea.scrollTop + msgArea.clientHeight >= msgArea.scrollHeight - 50;
      msgArea.appendChild(makeBubble(msg));
      if (atBottom) msgArea.scrollTop = msgArea.scrollHeight;
    }
  });

  // ─── Init ───
  loadChats();
})();
</script>
