<style>
  .api-card { transition: all 0.15s; }
  .api-card:hover { border-color: #22c55e; }
  .method-badge { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 11px; letter-spacing: 0.5px; }
  pre.code-block { background: #0f172a; color: #e2e8f0; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; font-size: 12px; line-height: 1.7; font-family: 'SF Mono', 'Fira Code', monospace; }
  .dark pre.code-block { background: #0c1222; }
</style>

<div class="mb-5">
  <p class="text-sm text-gray-500 dark:text-gray-400">Base URL: <code class="bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded text-xs font-mono text-green-600 dark:text-green-400"><%= baseUrl %></code></p>
  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">All endpoints require <code class="bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded text-xs">x-api-key</code> header. Session is auto-resolved from your API key.</p>
</div>

<div class="space-y-4">

  <!-- Authentication -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <h3 class="text-sm font-semibold mb-2">🔑 Authentication</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Get your API key from the <strong>Devices</strong> page. Add it to every request:</p>
    <div class="relative">
      <pre class="code-block">x-api-key: your-device-api-key</pre>
    </div>
  </div>

  <!-- Send to Person -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 api-card">
    <div class="flex items-center gap-3 mb-2">
      <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold">POST</span>
      <code class="text-sm font-mono text-gray-700 dark:text-gray-300">/api/send</code>
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Send a text message to a person. Just use the phone number — no need to add @s.whatsapp.net.</p>

    <h4 class="text-xs font-semibold text-gray-500 uppercase mb-1">Single recipient</h4>
    <div class="relative">
      <pre class="code-block">curl -X POST <%= baseUrl %>/api/send \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{ "to": "60123456789", "body": "Hello!" }'</pre>
    </div>

    <h4 class="text-xs font-semibold text-gray-500 uppercase mt-3 mb-1">Multiple recipients</h4>
    <div class="relative">
      <pre class="code-block">curl -X POST <%= baseUrl %>/api/send \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{
    "to": ["60123456789", "60198765432"],
    "body": "Broadcast message!"
  }'</pre>
    </div>
  </div>

  <!-- Send to Group -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 api-card">
    <div class="flex items-center gap-3 mb-2">
      <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold">POST</span>
      <code class="text-sm font-mono text-gray-700 dark:text-gray-300">/api/send-group</code>
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Send a text message to a group. Use the group JID (get it from the Groups button in Devices page).</p>

    <div class="relative">
      <pre class="code-block">curl -X POST <%= baseUrl %>/api/send-group \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{ "to": "120363012345@g.us", "body": "Hello group!" }'</pre>
    </div>
  </div>

  <!-- Send Image -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 api-card">
    <div class="flex items-center gap-3 mb-2">
      <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold">POST</span>
      <code class="text-sm font-mono text-gray-700 dark:text-gray-300">/api/send-message</code>
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Send an image with optional caption.</p>
    <div class="relative">
      <pre class="code-block">curl -X POST <%= baseUrl %>/api/send-message \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{
    "jid": "60123456789@s.whatsapp.net",
    "message": {
      "image": { "url": "https://example.com/photo.jpg" },
      "caption": "Check this out!"
    }
  }'</pre>
    </div>
  </div>

  <!-- Send Document -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 api-card">
    <div class="flex items-center gap-3 mb-2">
      <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold">POST</span>
      <code class="text-sm font-mono text-gray-700 dark:text-gray-300">/api/send-message</code>
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Send a document/file.</p>
    <div class="relative">
      <pre class="code-block">curl -X POST <%= baseUrl %>/api/send-message \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{
    "jid": "60123456789@s.whatsapp.net",
    "message": {
      "document": { "url": "https://example.com/report.pdf" },
      "mimetype": "application/pdf",
      "fileName": "report.pdf"
    }
  }'</pre>
    </div>
  </div>

  <div class="border-t border-gray-200 dark:border-gray-800 my-1"></div>

  <!-- Other Endpoints -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <h3 class="text-sm font-semibold mb-3">Other Endpoints</h3>
    <div class="space-y-3 text-sm">

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold shrink-0 mt-0.5">POST</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/send-message</code>
          <p class="text-xs text-gray-500 mt-0.5">Advanced: send with raw Baileys format — <code class="text-xs">{ "jid": "...@s.whatsapp.net", "message": { ... } }</code></p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 font-bold shrink-0 mt-0.5">GET</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/session</code>
          <p class="text-xs text-gray-500 mt-0.5">Check device connection status</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 font-bold shrink-0 mt-0.5">GET</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/groups</code>
          <p class="text-xs text-gray-500 mt-0.5">List all WhatsApp groups (id, name, member count)</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 font-bold shrink-0 mt-0.5">GET</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/contacts</code>
          <p class="text-xs text-gray-500 mt-0.5">Get all contacts for the device</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 font-bold shrink-0 mt-0.5">GET</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/messages</code>
          <p class="text-xs text-gray-500 mt-0.5">Get stored messages history</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400 font-bold shrink-0 mt-0.5">PUT</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/webhook</code>
          <p class="text-xs text-gray-500 mt-0.5">Set webhook URL — <code class="text-xs">{ "url": "https://..." }</code></p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold shrink-0 mt-0.5">POST</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/download-media</code>
          <p class="text-xs text-gray-500 mt-0.5">Download media from a received message (returns base64)</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold shrink-0 mt-0.5">POST</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/restart</code>
          <p class="text-xs text-gray-500 mt-0.5">Restart the device session</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="method-badge px-2 py-0.5 rounded bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-400 font-bold shrink-0 mt-0.5">POST</span>
        <div>
          <code class="font-mono text-gray-700 dark:text-gray-300">/api/read</code>
          <p class="text-xs text-gray-500 mt-0.5">Mark messages as read — <code class="text-xs">{ "keys": [{ "remoteJid": "...", "id": "..." }] }</code></p>
        </div>
      </div>

    </div>
  </div>

  <div class="border-t border-gray-200 dark:border-gray-800 my-1"></div>

  <!-- Webhook Payload -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <h3 class="text-sm font-semibold mb-2">📩 Webhook Payload</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">When a message is received, your webhook gets a POST with this payload:</p>

    <div class="relative">
      <pre class="code-block">{
  "event": "messages.upsert",
  "sessionId": "device-1",
  "data": {
    "key": {
      "remoteJid": "60123456789@s.whatsapp.net",
      "fromMe": false,
      "id": "BAE5A1234567890"
    },
    "pushName": "John",
    "message": {
      "conversation": "Hello!"
    },
    "messageTimestamp": 1707868800
  },
  "senderInfo": {
    "jid": "60123456789@s.whatsapp.net",
    "pushName": "John",
    "contactName": "John"
  }
}</pre>
    </div>

    <div class="mt-3 text-xs text-gray-500 dark:text-gray-400 space-y-1">
      <p>• For images: <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">message.imageMessage</code> with url, mimetype, caption</p>
      <p>• For documents: <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">message.documentMessage</code> with url, mimetype, fileName</p>
      <p>• Status updates: event = <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">messages.update</code> with status (server_ack, delivered, read)</p>
    </div>
  </div>

</div>
